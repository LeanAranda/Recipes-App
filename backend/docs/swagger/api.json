    "info": {
        "title": "Recipes API",
        "description": "API para recetas y ratings",
        "version": "1.0",
        "contact": {}
    },
    "tags": [],
    "servers": [],
    "components": {
        "schemas": {
            "CreateUserDto": {
                "type": "object",
                "properties": {
                    "firstName": {
                        "type": "string",
                        "description": "Primer nombre del usuario",
                        "example": "Pablo"
                    },
                    "lastName": {
                        "type": "string",
                        "description": "Apellido del usuario",
                        "example": "López"
                    },
                    "email": {
                        "type": "string",
                        "description": "Correo electrónico del usuario",
                        "example": "pablo.lopez@example.com"
                    },
                    "password": {
                        "type": "string",
                        "description": "Contraseña del usuario",
                        "example": "password123"
                    }
                },
                "required": [
                    "firstName",
                    "lastName",
                    "email",
                    "password"
                ]
            },
            "updateUserDto": {
                "type": "object",
                "properties": {
                    "firstName": {
                        "type": "string",
                        "description": "Primer nombre del usuario",
                        "example": "Pablo"
                    },
                    "lastName": {
                        "type": "string",
                        "description": "Apellido del usuario",
                        "example": "López"
                    },
                    "email": {
                        "type": "string",
                        "description": "Correo electrónico del usuario",
                        "example": "pablo.lopez@example.com"
                    },
                    "password": {
                        "type": "string",
                        "description": "Contraseña del usuario",
                        "example": "password123"
                    }
                }
            },
            "LoginUserDto": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "user@example.com",
                        "description": "Email del usuario"
                    },
                    "password": {
                        "type": "string",
                        "example": "password123",
                        "description": "Contraseña del usuario"
                    }
                },
                "required": [
                    "email",
                    "password"
                ]
            },
            "CreateRecipeDto": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "Título de la receta",
                        "example": "Panqueques"
                    },
                    "description": {
                        "type": "string",
                        "description": "Descripción de la receta",
                        "example": "Receta para hacer panqueques riquísimos"
                    },
                    "ingredients": {
                        "description": "Lista de ingredientes",
                        "example": [
                            "Harina",
                            "Huevos",
                            "Leche"
                        ],
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "imageUrl": {
                        "type": "string",
                        "description": "URL de la imagen de la receta",
                        "example": "https://example.com/panqueques.jpg"
                    }
                },
                "required": [
                    "title",
                    "description",
                    "ingredients",
                    "imageUrl"
                ]
            },
            "UpdateRecipeDto": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "Título de la receta",
                        "example": "Panqueques"
                    },
                    "description": {
                        "type": "string",
                        "description": "Descripción de la receta",
                        "example": "Receta para hacer panqueques riquísimos"
                    },
                    "ingredients": {
                        "description": "Lista de ingredientes",
                        "example": [
                            "Harina",
                            "Huevos",
                            "Leche"
                        ],
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "imageUrl": {
                        "type": "string",
                        "description": "URL de la imagen de la receta",
                        "example": "https://example.com/panqueques.jpg"
                    },
                    "deleted": {
                        "type": "boolean",
                        "description": "Indica si la receta está eliminada",
                        "example": false
                    }
                }
            },
            "CreateRatingDto": {
                "type": "object",
                "properties": {
                    "recipeId": {
                        "type": "number",
                        "description": "ID de la receta que se valora",
                        "example": 1
                    },
                    "score": {
                        "type": "number",
                        "description": "Puntuación de la receta entre 1 y 10",
                        "example": 8
                    }
                },
                "required": [
                    "recipeId",
                    "score"
                ]
            },
            "UpdateRatingDto": {
                "type": "object",
                "properties": {
                    "score": {
                        "type": "number",
                        "description": "Puntuación de la receta entre 1 y 10",
                        "example": 8
                    }
                },
                "required": [
                    "score"
                ]
            }
        }
    }
}